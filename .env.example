# Copia este archivo como .env y rellena los valores reales.
# Nunca subas .env al repositorio (debe estar en .gitignore).

# Entorno: development | staging | production
NODE_ENV=development

# Base de datos
DATABASE_URL=postgresql://usuario:password@localhost:5432/mi_app
# o para MySQL:
# DATABASE_URL=mysql://usuario:password@localhost:3306/mi_app

# API y secretos (usa valores de ejemplo; en producción usa secretos seguros)
API_KEY=tu_api_key_aqui
API_SECRET=tu_api_secret_aqui
JWT_SECRET=un_secreto_largo_y_aleatorio_para_jwt

# Servicios externos (ej. despliegue, almacenamiento)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EC2_IP=192.168.1.100

# App (puerto, URL pública, etc.)
PORT=3000
APP_URL=http://localhost:3000
